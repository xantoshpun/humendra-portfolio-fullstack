generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth.js standard tables ────────────────────────────────
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())

  accounts Account[]
  sessions Session[]
}

enum Role {
  ADMIN
  USER
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Content tables ─────────────────────────────────────────
model SiteMeta {
  id        String   @id @default(cuid())
  name      String
  initials  String
  location  String
  email     String
  heroBio   String
  titles    String[]
  socials   Json // { linkedin, github, kaggle, resume }
  updatedAt DateTime @updatedAt
}

model About {
  id              String   @id @default(cuid())
  paragraphs      String[] // each may contain HTML for inline emphasis
  cards           Json // [{ icon, title, sub }]
  terminalPassion String?
  updatedAt       DateTime @updatedAt
}

model Skill {
  id        String   @id @default(cuid())
  icon      String
  title     String
  color     String // "cyan" | "purple" | "green"
  tags      String[]
  order     Int      @default(0)
  updatedAt DateTime @updatedAt

  @@index([order])
}

model Education {
  id          String   @id @default(cuid())
  degree      String
  institution String
  date        String // free-form e.g. "October 2023"
  honour      String?
  honourColor String?
  focus       String[]
  order       Int      @default(0)
  updatedAt   DateTime @updatedAt

  @@index([order])
}

model Experience {
  id         String   @id @default(cuid())
  role       String
  company    String
  date       String
  badgeColor String?
  badgeText  String?
  skills     String[]
  order      Int      @default(0)
  updatedAt  DateTime @updatedAt

  @@index([order])
}

model Certification {
  id        String   @id @default(cuid())
  img       String? // icon filename in /public/icons/
  name      String
  issuer    String
  date      String
  order     Int      @default(0)
  updatedAt DateTime @updatedAt

  @@index([order])
}

model Stat {
  id        String   @id @default(cuid())
  value     Float
  prefix    String?
  suffix    String?
  display   String // pre-rendered display string e.g. "↓60%"
  label     String
  accent    String // "cyan" | "purple" | "green" | "amber"
  order     Int      @default(0)
  updatedAt DateTime @updatedAt

  @@index([order])
}

model Project {
  id           String    @id @default(cuid())
  slug         String    @unique
  title        String
  summary      String
  body         String // Markdown
  thumbnailUrl String?
  techTags     String[]
  liveUrl      String?
  repoUrl      String?
  order        Int       @default(0)
  featured     Boolean   @default(false)
  publishedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([publishedAt])
  @@index([order])
}
